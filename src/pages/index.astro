    homepage: 'https://zongyuange.github.io/',
    role: 'Group Leader',
    photo: '/avatar/zongyuan ge.png',
    bio: 'Founding Director of the AIM for Health Lab'
  },
  {
    name: 'Xuelian Cheng',
    homepage: 'https://xueliancheng.github.io/',
    role: 'Team Leader',
    photo: '/avatar/xuelian cheng.png',
    bio: 'Adjunct Lecturer, Monash University'
  },
  {
    name: 'Shiyan Su',
    homepage: 'https://github.com/ooonesevennn',
