    ],
    status: 'accepted' as const,
    previewImage: '/images/paper/ColonAdapter.png',
  }
]

const publicationYear = (title: string) => {
  const y = publications.find((p) => p.title === title)?.year
  return y !== undefined ? parseInt(y, 10) : Number.POSITIVE_INFINITY
}

/** Newest year first within each research direction (below Featured Research Projects). */
const sortPapersNewestFirst = <
  T extends { title: string; href: string; meta: string }
>(
  papers: T[]
) => [...papers].sort((a, b) => publicationYear(b.title) - publicationYear(a.title))

const researchDirections = [
  {
    title: 'Multimodal World Model',
    description:
      'Enables systems to perceive, interpret, and reason about dynamic scenes from videos and 3D representations.',
    image: '/images/Multimodal World Model.png',
    papers: [
      {
        title: 'Implicit Motion Handling for Video Camouflaged Object Detection',
        href: 'https://openaccess.thecvf.com/content/CVPR2022/papers/Cheng_Implicit_Motion_Handling_for_Video_Camouflaged_Object_Detection_CVPR_2022_paper.pdf',
        meta: 'CVPR 2022'
      },
      {
        title: 'Video-Thinker: Sparking "Thinking with Videos" via Reinforcement Learning',
        href: 'https://arxiv.org/abs/2510.23473',
        meta: 'Submitted to ICML 2026'
      }
    ]
  },
  {
    title: 'Geometry Estimation and 3D Reconstruction',
    description:
      'Focuses on recovering accurate 3D geometry, depth, and structure from visual data, especially in medical scenarios.',
    image: '/images/Geometry Estimation and 3D Reconstruction.png',
    papers: [
      {
        title: 'Deep laparoscopic stereo matching with transformers',
        href: 'https://arxiv.org/pdf/2207.12152.pdf',
        meta: 'MICCAI 2022'
      },
      {
        title:
          'EndoSurf: Neural Surface Reconstruction of Deformable Tissues with Stereo Endoscope Videos',
        href: 'https://arxiv.org/abs/2307.11307',
        meta: 'MICCAI 2023 Oral'
      },
      {
        title:
          'DiffNR: Diffusion-Enhanced Neural Representation Optimization for Sparse-View 3D Tomographic Reconstruction',
        href: 'https://github.com/ooonesevennn/DiffNR',
        meta: 'AAAI 2026'
      },
      {
        title: "ColonAdapter: Geometry Estimation Through Foundation Model Adaptation for Colonoscopy",
        href: "https://ieeexplore.ieee.org/abstract/document/11214345",
        meta: "IEEE Transactions on Medical Imaging 2025"
      }
    ]
  },
  {
    title: 'Registration',
    description:
      'Studies robust alignment between 2D and 3D data to support precise applications such as surgical navigation.',
    image: '/images/Registration.png',
    papers: [
      
    ]
  },
  {
    title: 'Digital Twins',
    description:
      'Explores building virtual environments and multimodal intelligent systems for simulation and embodied interaction.',
    image: '/images/Digital Twins.png',
    papers: [
      {
        title: 'RoomPlanner: Explicit Layout Planner for Easier LLM-Driven 3D Room Generation',
        href: 'https://arxiv.org/pdf/2511.17048',
        meta: 'Preprint'
      }
    ]
  }
]

const researchDirectionsOrdered = researchDirections.map((direction) => ({
  ...direction,
  papers: direction.papers ? sortPapersNewestFirst(direction.papers) : direction.papers
}))

const researchDirectionsWithLinks = researchDirectionsOrdered.map((direction) => ({
  ...direction,
  readMoreHref:
    direction.papers && direction.papers.length > 0
      ? `#${toAnchorId(direction.papers[0].title)}`
      : '#publications'
}))

const publicationsByDirection = researchDirectionsWithLinks
  .map((direction) => ({
    ...direction,
    publications:
      direction.papers
        ?.map((paper) => publications.find((publication) => publication.title === paper.title))
        .filter((publication): publication is (typeof publications)[number] =>
          Boolean(publication)
        ) || []
  }))
  .filter((direction) => direction.publications.length > 0)
---

<PageLayout
  meta={{
    title: 'Home',
    description:
      'AIM for Health (Suzhou) | Embodied AI explores embodied intelligence, multimodal world models, and human-centered AI systems.'
  }}
  highlightColor='#2E8B7B55'
>
  <main
    class='landing-shell relative left-1/2 w-screen -translate-x-1/2 overflow-x-hidden pt-12 text-slate-900 selection:bg-emerald-500/30 dark:text-slate-100'
  >
    <div class='hero-light hero-light-a'></div>
    <div class='hero-light hero-light-b'></div>
    <div class='hero-light hero-light-c'></div>
    <div
      class='pointer-events-none absolute inset-x-0 top-0 h-[760px] bg-[linear-gradient(to_right,#80808008_1px,transparent_1px),linear-gradient(to_bottom,#80808008_1px,transparent_1px)] bg-[size:24px_24px] opacity-60 [mask-image:radial-gradient(ellipse_62%_52%_at_50%_0%,#000_64%,transparent_100%)] dark:bg-[linear-gradient(to_right,#ffffff05_1px,transparent_1px),linear-gradient(to_bottom,#ffffff05_1px,transparent_1px)] dark:opacity-40'
    >
    </div>
    <div
      class='pointer-events-none absolute left-1/2 top-24 -z-10 h-[420px] w-[760px] -translate-x-1/2 rounded-full bg-emerald-400/5 blur-[120px] dark:bg-teal-700/10'
    >
    </div>

    <section
      id='vision'
      class='landing-panel relative flex min-h-[90vh] snap-start items-center px-6 pb-20 pt-16 sm:px-10 sm:pt-24 lg:px-16 lg:pt-0'
    >
      <div class='relative z-10 mx-auto mt-0 w-full max-w-7xl lg:mt-0'>
        <div class='reveal-on-scroll is-visible max-w-4xl space-y-8'>
          <div class='max-w-4xl space-y-6'>
            <h1
              class='text-5xl font-extrabold leading-[1.05] tracking-tighter text-slate-900 dark:text-white sm:text-6xl lg:text-[5.5rem]'
            >
              AIM for Health (Suzhou) <span
                class='bg-gradient-to-br from-primary via-cyan-500 to-cyan-300 bg-clip-text text-transparent dark:from-primary dark:via-cyan-400 dark:to-cyan-200'
                >Embodied AI Team</span
              >
            </h1>
            <p
              class='max-w-2xl text-lg leading-relaxed text-slate-500 dark:text-slate-400 sm:text-xl'
            >
              <span class='hero-slogan-wrap'>
                <span class='hero-slogan is-active' data-lang='en'
                  >See the unseen, shape the shell</span
                >
                <span class='hero-slogan' data-lang='zh'>洞见未见，塑以躯壳</span>
                <span class='hero-slogan' data-lang='ja'>見えないものを捉え、形を与える</span>
              </span>
            </p>
          </div>
          <div class='flex flex-wrap gap-4 pt-4'>
            <Button
              href='/#team'
              title='Meet the Team'
              class='rounded-full border border-slate-900 bg-slate-900 px-7 py-3.5 text-[13px] font-semibold tracking-wide !text-white shadow-[0_4px_14px_rgba(0,0,0,0.1)] transition-all duration-300 hover:-translate-y-0.5 hover:border-slate-800 hover:bg-slate-800 hover:!text-white hover:shadow-[0_6px_20px_rgba(0,0,0,0.15)] dark:border-white dark:bg-white dark:!text-slate-900 dark:hover:border-slate-100 dark:hover:bg-slate-100 dark:hover:!text-slate-900'
            />
            <Button
              href='/#publications'
              title='View Research'
              class='rounded-full border border-slate-200/80 bg-white/50 px-7 py-3.5 text-[13px] font-semibold tracking-wide text-slate-700 shadow-[0_2px_8px_rgba(0,0,0,0.03)] backdrop-blur transition-all duration-300 hover:-translate-y-0.5 hover:border-slate-300 hover:bg-white/80 hover:text-slate-900 hover:shadow-[0_6px_20px_rgba(0,0,0,0.08)] dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:border-white/20 dark:hover:bg-white/10 dark:hover:text-white'
            />
          </div>
        </div>
      </div>
    </section>

    <div class='mx-auto w-full max-w-7xl px-6 sm:px-10 lg:px-16'>
      <div class='w-full border-t border-dashed border-slate-300 dark:border-slate-800'></div>
    </div>

    <section
      id='team'
      class='landing-panel relative flex min-h-[85vh] items-center px-6 py-24 sm:px-10 lg:px-16'
    >
      <div
        class='reveal-on-scroll relative z-10 mx-auto w-full max-w-7xl space-y-16 text-center'
        data-reveal-delay='0'
      >
        <div class='mx-auto max-w-3xl space-y-5'>
          <p
            class='font-mono text-[10px] font-semibold uppercase tracking-[0.2em] text-slate-400 dark:text-slate-500'
          >
            [ Team ]
          </p>
          <h2
            class='text-4xl font-bold leading-tight tracking-tight text-slate-900 dark:text-white sm:text-5xl'
          >
            Meet the Team
          </h2>
        </div>

        <div class='space-y-16'>
          <!-- Teachers -->
          <div>
            <div class='mx-auto flex flex-wrap justify-center gap-x-16 gap-y-12'>
              {
                members
                  .slice(0, 2)
                  .map((member, index) => (
                    <MemberCard
                      member={member}
                      class='reveal-on-scroll'
                      data-reveal-delay={String(index * 80)}
                    />
                  ))
              }
            </div>
          </div>

          <div class='mx-auto w-full max-w-md'>
            <div class='w-full border-t border-dashed border-slate-300 dark:border-slate-800'></div>
          </div>

          <!-- Students -->
          <div>
            <div class='mx-auto flex flex-wrap justify-center gap-x-12 gap-y-12'>
              {
                members
                  .slice(2)
                  .map((member, index) => (
                    <MemberCard
                      member={member}
                      class='reveal-on-scroll'
                      data-reveal-delay={String(80 + index * 70)}
                    />
                  ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class='mx-auto w-full max-w-7xl px-6 sm:px-10 lg:px-16'>
      <div class='w-full border-t border-dashed border-slate-300 dark:border-slate-800'></div>
    </div>

    <section
      id='about'
      class='landing-panel relative flex min-h-[80vh] items-center px-6 py-24 sm:px-10 lg:px-16'
    >
      <div class='reveal-on-scroll relative z-10 mx-auto w-full max-w-7xl' data-reveal-delay='40'>
        <div class='grid grid-cols-1 items-stretch gap-5 lg:grid-cols-12 lg:gap-10'>
          <!-- Image (Left) -->
          <div class='w-full lg:col-span-5'>
            <div
              class='relative h-full min-h-[350px] w-full overflow-hidden rounded-[2rem] border border-slate-200/50 shadow-[0_8px_30px_rgba(0,0,0,0.04)] dark:border-white/5'
            >
              <img
                src='/images/Embody AI Logo.jpg'
                alt='Spatial Perception Research'
                class='absolute inset-0 h-full w-full object-cover transition-transform duration-1000 hover:scale-105'
                loading='lazy'
              />
            </div>
          </div>

          <!-- Text block (Right) -->
          <div
            class='flex h-full flex-col justify-center rounded-[2rem] border border-slate-200/50 bg-white/60 p-8 shadow-[0_8px_30px_rgba(0,0,0,0.02)] backdrop-blur-sm dark:border-white/5 dark:bg-white/[0.02] sm:p-10 lg:col-span-7 lg:p-16'
          >
            <div
              class='mb-6 font-mono text-[10px] font-semibold uppercase tracking-widest text-slate-400 dark:text-slate-500'
            >
              [ About The Team ]
            </div>

            <h2
              class='text-3xl font-semibold leading-[1.17] tracking-tight text-slate-900 dark:text-white sm:text-4xl lg:text-[2.8rem] lg:leading-[1.17]'
            >
              We build intelligent visual systems that bridge <span class='text-primary'
                >embodied AI</span
              > and <span class='text-primary'>clinical medicine.</span>
            </h2>

            <div class='mt-10 max-w-2xl border-l-2 border-slate-200/80 pl-6 dark:border-slate-800'>
              <p class='text-[17px] leading-relaxed text-slate-500 dark:text-slate-400'>
                Leveraging 3D scene understanding, multimodal agents, and geometry-aware
                reconstruction to advance spatial perception and interaction across surgical
                scenarios and digital twins.
              </p>
            </div>

            <div class='mt-12 flex items-center gap-6'>
              <a
                href='#publications'
                class='group flex items-center gap-2 text-[13px] font-semibold uppercase tracking-widest text-slate-900 transition-colors hover:text-primary dark:text-white dark:hover:text-primary'
              >
                Explore Papers
                <span class='transition-transform group-hover:translate-x-2'>→</span>
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class='mx-auto w-full max-w-7xl px-6 sm:px-10 lg:px-16'>
      <div class='w-full border-t border-dashed border-slate-300 dark:border-slate-800'></div>
    </div>

    <section
      id='research-directions'
      class='landing-panel relative flex min-h-screen items-center px-0 py-0'
    >
      <div
        class='reveal-on-scroll relative z-10 w-full bg-[#0a0a0a] px-6 py-20 text-white sm:px-10 sm:py-24 lg:px-16 lg:py-28'
        data-reveal-delay='50'
      >
        <div
          class='pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(6,182,212,0.05),transparent_40%),radial-gradient(circle_at_bottom_left,rgba(45,212,191,0.05),transparent_40%)]'
        >
        </div>

        <div
          class='relative mx-auto flex min-h-[100vh] w-full max-w-7xl flex-col justify-center gap-14'
        >
          <div class='max-w-4xl space-y-5 pt-2'>
            <p
              class='font-mono text-[10px] font-semibold uppercase tracking-[0.28em] text-white/40'
            >
              [ Research Directions ]
            </p>
            <h2
              class='text-4xl font-semibold leading-none tracking-tight text-white sm:text-5xl lg:text-[4.5rem]'
            >
              Our Research Areas
            </h2>
            <p class='max-w-3xl text-lg leading-[1.55] text-white/70 sm:text-xl'></p>
          </div>

          <div class='grid gap-6 xl:grid-cols-2'>
            {
              researchDirectionsWithLinks.map((direction, index) => (
                <article
                  class='reveal-on-scroll group relative min-h-[420px] overflow-hidden rounded-[1.9rem] bg-slate-900 shadow-[0_8px_30px_rgba(0,0,0,0.06)]'
                  data-reveal-delay={String(80 + index * 70)}
                >
                  <img
                    src={direction.image}
                    alt={direction.title}
                    class='absolute inset-0 h-full w-full object-cover transition-transform duration-700 group-hover:scale-[1.04]'
                    loading='lazy'
                  />
                  <div class='absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-black/30 transition-colors duration-500 group-hover:bg-black/10' />

                  <div class='relative flex h-full flex-col justify-between p-7 sm:p-9'>
                    <div class='space-y-4'>
                      <h3 class='font-mono text-[0.95rem] font-semibold uppercase tracking-[0.16em] text-white sm:text-[1.02rem]'>
                        {direction.title}
                      </h3>
                    </div>

                    <div class='space-y-4'>
                      <p class='max-w-xl text-[15px] leading-7 text-white/80 sm:text-base'>
                        {direction.description ||
                          'Publications for this direction will be added soon.'}
                      </p>

