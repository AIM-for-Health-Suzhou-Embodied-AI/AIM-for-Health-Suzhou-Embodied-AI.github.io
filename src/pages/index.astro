---
import PageLayout from '@/layouts/BaseLayout.astro'
import { Button, MemberCard, PublicationSection } from '@/components/user'
import { title } from 'node:process'

const toAnchorId = (value: string) =>
  `publication-${value
    .toLowerCase()
    .replace(/[^a-z0-9\s-]/g, '')
    .trim()
    .replace(/\s+/g, '-')}`

const members = [
