---
import { cn } from '@/utils'

interface Props {
  class?: string
  eyebrow?: string
  title: string
  description: string
}

const { class: className, eyebrow, title, description } = Astro.props
---

<article
  class={cn(
    'relative overflow-hidden rounded-[2rem] border border-white/60 bg-white/78 p-8 shadow-[0_24px_80px_rgba(15,23,42,0.1)] dark:border-white/10 dark:bg-white/5',
    className
  )}
>
  <div class='absolute inset-y-0 left-0 w-1 bg-gradient-to-b from-emerald-400 to-amber-300'></div>
  <div class='ml-2 space-y-5'>
    {eyebrow && <p class='text-xs font-semibold uppercase tracking-[0.24em] text-primary/75'>{eyebrow}</p>}
    <h3 class='max-w-3xl text-3xl font-semibold leading-tight text-slate-950 dark:text-white sm:text-4xl'>
      {title}
    </h3>
    <p class='max-w-4xl text-base leading-8 text-slate-600 dark:text-slate-300 sm:text-lg'>{description}</p>
  </div>
</article>
