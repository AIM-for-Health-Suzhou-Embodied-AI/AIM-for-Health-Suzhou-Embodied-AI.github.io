</PageLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slogans = Array.from(document.querySelectorAll('.hero-slogan')) as HTMLElement[]
    let activeSlogan = 0
    if (slogans.length > 1) {
      window.setInterval(() => {
        const current = slogans[activeSlogan]
        current?.classList.remove('is-active')
        current?.classList.add('is-exiting')

        activeSlogan = (activeSlogan + 1) % slogans.length
        
        const next = slogans[activeSlogan]
        if (next) {
          next.style.transition = 'none'
          next.classList.remove('is-exiting')
          // Force layout recalculation to snap back to start position
          void next.offsetWidth
          next.style.transition = ''
          next.classList.add('is-active')
        }
      }, 3200)
    }

    const elements = document.querySelectorAll('.reveal-on-scroll')
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const delay = entry.target.getAttribute('data-reveal-delay') || '0'
            entry.target.setAttribute('style', `transition-delay:${delay}ms`)
            entry.target.classList.add('is-visible')
            observer.unobserve(entry.target)
          }
        })
      },
      { threshold: 0.14, rootMargin: '0px 0px -8% 0px' }
    )

    elements.forEach((el) => {
      if (!el.classList.contains('is-visible')) observer.observe(el)
    })
  })
</script>

