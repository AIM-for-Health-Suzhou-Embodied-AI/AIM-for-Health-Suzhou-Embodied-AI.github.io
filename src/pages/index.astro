    previewAlt: 'EndoSurf paper preview'
  },
  {
    title: 'Video-Thinker: Sparking "Thinking with Videos" via Reinforcement Learning',
    authors: [
      { name: 'Shijian Wang' },
      { name: 'Jiarui Jin' },
      { name: 'Xingjian Wang' },
      { name: 'Linxin Song' },
      { name: 'Runhao Fu' },
