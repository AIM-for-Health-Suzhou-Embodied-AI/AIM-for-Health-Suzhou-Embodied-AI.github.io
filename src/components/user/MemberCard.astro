---
import { cn } from '@/utils'

interface Props {
  class?: string
  member: {
    name: string
    role: string
    photo: string
    bio?: string
  }
}

const { class: className, member, ...props } = Astro.props
---

<article
  class={cn(
    'group relative flex w-full max-w-[22rem] flex-col items-center gap-5 rounded-2xl p-2 text-center transition-all duration-300 hover:-translate-y-1',
    className
  )}
  {...props}
>
  <div class='h-32 w-32 shrink-0 overflow-hidden rounded-2xl bg-slate-100 shadow-[0_18px_45px_rgba(15,23,42,0.08)] dark:bg-slate-900/80 dark:shadow-[0_18px_45px_rgba(0,0,0,0.28)]'>
    <img
      src={member.photo}
      alt={member.name}
      class='h-full w-full object-cover transition-transform duration-500 group-hover:scale-110'
      loading='lazy'
    />
  </div>
  <div class='flex flex-col items-center gap-1.5'>
    <h3 class='text-lg font-bold text-slate-900 dark:text-white'>{member.name}</h3>
    <p class='text-xs font-semibold uppercase tracking-wider text-primary/80'>{member.role}</p>
    {member.bio && <p class='max-w-[18rem] text-sm leading-relaxed text-slate-600 dark:text-slate-300 line-clamp-3'>{member.bio}</p>}
  </div>
</article>
