      {
        type: 'pdf',
        href: 'https://openaccess.thecvf.com/content/CVPR2022/papers/Cheng_Implicit_Motion_Handling_for_Video_Camouflaged_Object_Detection_CVPR_2022_paper.pdf'
      },
      { type: 'code', href: 'https://github.com/XuelianCheng/SLT-Net' },
