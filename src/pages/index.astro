    links: [
      { type: 'arxiv', href: 'https://arxiv.org/abs/2510.23473' },
      { type: 'code', href: 'https://github.com/shijian2001/Video-Thinker' },
      { type: 'model', href: 'https://huggingface.co/ShijianW01/Video-Thinker-7B' },
      { type: 'website', href: 'https://mp.weixin.qq.com/s/aI0vwG5e1U03Squ0rJzcIQ' }
