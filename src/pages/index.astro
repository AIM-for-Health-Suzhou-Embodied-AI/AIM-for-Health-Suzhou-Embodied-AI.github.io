    year: '2025',
    type: 'conference' as const,
    abstract: '',
    links: [{ type: 'arxiv', href: 'https://arxiv.org/pdf/2511.17048' }],
    status: 'preprint' as const,
    previewImage: '/images/paper/RoomPlanner.png',
    previewAlt: 'RoomPlanner paper preview'
  },
  {
    title: "ColonAdapter: Geometry Estimation Through Foundation Model Adaptation for Colonoscopy",
    authors: [
      { name: 'Zhiyi Jiang' },
      { name: ''}
    ],
    type: 'journal' as const,
    venue: 'IEEE Robotics and Automation Letters',
    year: '2025',
    links: [
      {type: 'ieee', href: "https://ieeexplore.ieee.org/abstract/document/11214345"},
      {type: 'arxiv', href: "https://arxiv.org/abs/2511.22250 "},
